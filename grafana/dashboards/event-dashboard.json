          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ROUND(\n  AVG(\n    EXTRACT(EPOCH FROM (purchase_time - view_time)) / 60.0\n  )::numeric,\n  1\n) AS avg_conversion_minutes\nFROM (\n  SELECT\n    s.session_id,\n    MIN(s.event_time) AS view_time,\n    MIN(p.event_time) AS purchase_time\n  FROM event_logs s\n  JOIN event_logs p\n    ON s.session_id = p.session_id\n   AND p.event_type = 'PURCHASE_COMPLETED'\n  WHERE s.event_type = 'PRODUCT_VIEW'\n  GROUP BY s.session_id\n) sub\nWHERE purchase_time > view_time",
          "refId": "A"
        }
      ],
      "title": "평균 구매 전환 시간",
