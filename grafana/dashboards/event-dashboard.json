          "id": "convertFieldType",
          "options": {
            "conversions": [
              { "destinationType": "string", "targetField": "funnel_step" }
            ]
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "step_order": true },
            "renameByName": {
              "funnel_step": "단계",
              "session_count": "세션 수"
            }
          }
        }
