          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  'PRODUCT_VIEW'       AS funnel_step,\n  1                    AS step_order,\n  COUNT(DISTINCT session_id) AS session_count\nFROM event_logs\nWHERE event_type = 'PRODUCT_VIEW'\n\nUNION ALL\n\nSELECT\n  'ADD_TO_CART'        AS funnel_step,\n  2                    AS step_order,\n  COUNT(DISTINCT session_id) AS session_count\nFROM event_logs\nWHERE event_type = 'ADD_TO_CART'\n\nUNION ALL\n\nSELECT\n  'PURCHASE_COMPLETED' AS funnel_step,\n  3                    AS step_order,\n  COUNT(DISTINCT session_id) AS session_count\nFROM event_logs\nWHERE event_type = 'PURCHASE_COMPLETED'\n\nORDER BY step_order",
          "refId": "A"
        }
      ],
